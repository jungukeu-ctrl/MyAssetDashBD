{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/set-code-auth.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/check-code-auth.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/impact-check.sh",
            "timeout": 5,
            "statusMessage": "웹 영향도 분석 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/sync-plan.sh 2>/dev/null || true",
            "timeout": 60,
            "statusMessage": "PLAN.md → main 동기화 중..."
          }
        ]
      }
    ]
  }
}
